# Copy to .local.env and fill in. .local.env is gitignored - never commit it.
# Kria KV260 is Ethernet-only (no WiFi), so there are no WiFi credentials here.
# The board's IP is pinned by a DHCP reservation on the router, not on the board,
# so no GATEWAY/DNS is needed here.

DEVICE_IP=192.168.50.27        # board's IP (must match the router's DHCP reservation)
DEVICE_USER=ubuntu             # DUT login user
DEVICE_PASSWORD=changeme       # DUT login password
