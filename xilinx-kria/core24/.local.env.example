# Copy to .local.env and fill in. .local.env is gitignored - never commit it.
# Kria KV260 on Ubuntu Core 24: Ethernet-only (no WiFi), IP pinned by a router
# DHCP reservation (no GATEWAY/DNS needed here).

DEVICE_IP=192.168.50.27        # board's IP (must match the router's DHCP reservation)
DEVICE_USER=ubuntu             # UC24 first user (set during console-conf)
DEVICE_PASSWORD=changeme       # that user's password
