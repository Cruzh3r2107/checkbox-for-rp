#!/usr/bin/env checkbox-cli

[launcher]
launcher_version = 1
stock_reports = text, submission_files, json

[test plan]
unit = com.canonical.contrib::ce-oem-iot-server-24-04-automated
forced = yes

[test selection]
forced = yes

[ui]
type = silent
auto_retry = yes
max_attempts = 3
delay_before_retry = 15

[environment]
# WiFi credentials for the wireless tests. Leave empty if the board has no WiFi.
WPA_BG_SSID=
WPA_BG_PSK=
WPA_N_SSID=
WPA_N_PSK=
WPA_AC_SSID=
WPA_AC_PSK=

# RTC: set to the number of /dev/rtc devices the board has (0 if none).
TOTAL_RTC_NUM=0
