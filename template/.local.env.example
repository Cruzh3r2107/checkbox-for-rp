# Copy this to .local.env in your board folder and fill it in.
# .local.env is gitignored, so your IP and passwords are never committed.

PI_IP=192.168.1.50          # board IP (pin it with a router DHCP reservation)
PI_USER=ubuntu              # board login user
PI_PASSWORD=changeme        # board login password
WIFI_SSID=YourWiFiName      # lab WiFi name (for wireless tests; leave empty if the board has no WiFi)
WIFI_PSK=YourWiFiPassword   # lab WiFi password
