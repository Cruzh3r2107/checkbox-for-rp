# Copy to .local.env and fill in. .local.env is gitignored - never commit it.
# The Pi's Ethernet IP is pinned by a DHCP reservation on the router (not the
# board), so no GATEWAY/DNS/WiFi-IP is needed here. WiFi creds are only used by
# the launcher's wireless tests (transient association to the lab AP).

DEVICE_IP=192.168.50.XX        # Pi end0 IP (must match the router's DHCP reservation)
DEVICE_USER=ubuntu             # DUT login user
DEVICE_PASSWORD=changeme       # DUT login password
WIFI_SSID=YourNewSSID          # new router's WiFi SSID (for wireless tests)
WIFI_PSK=YourNewPassword       # new router's WiFi password
