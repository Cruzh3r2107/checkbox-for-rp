# Copy to .local.env and fill in. .local.env is gitignored - never commit it.
# Pi 4 Server 24.04: Ethernet IP pinned by router DHCP reservation (no GATEWAY/DNS
# needed here). WiFi creds are used by the launcher's wireless tests.

DEVICE_IP=192.168.50.47        # Pi eth0 IP (must match the router's DHCP reservation)
DEVICE_USER=ubuntu             # Server login user
DEVICE_PASSWORD=changeme       # Server login password (for Envicorn + sudo priming)
WIFI_SSID=YourSSID             # lab WiFi SSID (for wireless tests)
WIFI_PSK=YourWiFiPassword      # lab WiFi password
