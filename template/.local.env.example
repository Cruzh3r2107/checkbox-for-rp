# Copy this to .local.env in your board folder and fill it in.
# .local.env is gitignored, so your IP and passwords are never committed.
# Used by the generic run.sh (and the legacy PI_*/KRIA_* names still work).

DEVICE_IP=192.168.1.50          # board IP (pin it with a router DHCP reservation)
DEVICE_USER=ubuntu              # board login user
DEVICE_PASSWORD=changeme        # board login password (leave empty for Core SSH-key auth)
WIFI_SSID=YourWiFiName          # lab WiFi name (leave empty if the board has no WiFi)
WIFI_PSK=YourWiFiPassword       # lab WiFi password
WATCHDOG_MODULE=bcm2835_wdt     # watchdog kernel module (Pi: bcm2835_wdt, Kria: cadence_wdt, i.MX93: imx2_wdt)
